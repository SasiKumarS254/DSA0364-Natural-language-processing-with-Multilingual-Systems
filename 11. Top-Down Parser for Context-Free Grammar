grammar = {
    'S': [['NP', 'VP']],
    'NP': [['John']],
    'VP': [['likes', 'apples']]
}

sentence = ['John', 'likes', 'apples']

def parse(symbol, words):
    if symbol not in grammar:
        return words and words[0] == symbol, words[1:]

    for rule in grammar[symbol]:
        remaining = words
        success = True

        for sym in rule:
            success, remaining = parse(sym, remaining)
            if not success:
                break

        if success:
            return True, remaining

    return False, words

result, remaining = parse('S', sentence)

if result and not remaining:
    print("Accepted")
else:
    print("Rejected")

import nltk
from nltk import CFG
from nltk.parse import EarleyChartParser

grammar = CFG.fromstring("""
S -> NP VP
NP -> 'John'
VP -> V NP
V -> 'likes'
NP -> 'apples'
""")

parser = EarleyChartParser(grammar)

sentence = "John likes apples".split()

for tree in parser.parse(sentence):
    print(tree)
